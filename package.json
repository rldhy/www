{
  "name": "rlodhiya-personal-site",
  "description": "Sharing my projects, hobbies, and interests.",
  "repository": "https://github.com/rldhy/www",
  "license": "MIT",
  "author": "Ritwik Lodhiya <hello@rlodhiya.dev>",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "clean": "rm -rf ./node_modules ./.next ./.content-collections",
    "start": "next dev",
    "dev": "cross-env INIT_CWD=$PWD next dev",
    "build": "cross-env INIT_CWD=$PWD && node ./scripts/prebuild.mjs && next build && node ./scripts/postbuild.mjs",
    "serve": "next start",
    "analyze": "cross-env ANALYZE=true next build",
    "lint": "eslint --fix app components layouts scripts services"
  },
  "dependencies": {
    "@getbrevo/brevo": "5.0.4",
    "@hcaptcha/react-hcaptcha": "2.0.2",
    "@headlessui/react": "2.2.10",
    "@next/bundle-analyzer": "16.2.9",
    "@tailwindcss/forms": "0.5.11",
    "@tailwindcss/postcss": "4.3.1",
    "@tailwindcss/typography": "0.5.20",
    "esbuild": "0.28.1",
    "github-slugger": "2.0.0",
    "gray-matter": "4.0.3",
    "image-size": "2.0.2",
    "kbar": "0.1.0-beta.48",
    "next": "16.2.9",
    "next-themes": "0.4.6",
    "node-cache": "5.1.2",
    "pino": "10.3.1",
    "pino-pretty": "13.1.3",
    "postcss": "8.5.15",
    "probe-image-size": "7.3.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-pdf": "10.4.1",
    "reading-time": "1.5.0",
    "rehype-autolink-headings": "7.1.0",
    "rehype-citation": "2.3.2",
    "rehype-katex": "7.0.1",
    "rehype-preset-minify": "7.0.1",
    "rehype-prism-plus": "2.0.2",
    "rehype-slug": "6.0.0",
    "remark": "15.0.1",
    "remark-gfm": "4.0.1",
    "remark-math": "6.0.0",
    "resend": "6.14.0",
    "tailwindcss": "4.3.1",
    "unist-util-visit": "5.1.0",
    "uuid": "14.0.1"
  },
  "devDependencies": {
    "@content-collections/core": "0.15.2",
    "@content-collections/mdx": "0.2.2",
    "@content-collections/next": "0.2.11",
    "@eslint/eslintrc": "3.3.5",
    "@eslint/js": "10.0.1",
    "@hcaptcha/types": "1.2.0",
    "@svgr/webpack": "8.1.0",
    "@types/mdx": "2.0.14",
    "@types/node": "26.0.0",
    "@types/react": "19.2.17",
    "@typescript-eslint/eslint-plugin": "8.62.0",
    "@typescript-eslint/parser": "8.62.0",
    "cross-env": "10.1.0",
    "eslint": "10.5.0",
    "eslint-config-next": "16.2.9",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-prettier": "5.5.6",
    "globals": "17.7.0",
    "lint-staged": "17.0.8",
    "prettier": "3.8.4",
    "prettier-plugin-tailwindcss": "0.8.0",
    "typescript": "6.0.3",
    "typescript-eslint": "8.62.0",
    "yarn-upgrade-all": "0.8.1",
    "zod": "4.4.3"
  },
  "lint-staged": {
    "*.+(js|jsx|ts|tsx)": [
      "eslint --fix"
    ],
    "*.+(js|jsx|ts|tsx|json|css|md|mdx)": [
      "prettier --write"
    ]
  },
  "packageManager": "yarn@3.6.1"
}
